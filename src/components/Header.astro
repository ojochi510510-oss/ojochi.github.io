---
import { noteConfig } from "../data/site";

interface Props {
	title: string;
	currentPath?: string;
}

const { title, currentPath = "/" } = Astro.props;
const BASE_URL = import.meta.env.BASE_URL;
const navItems = [
	{ href: `${BASE_URL}`, label: "Home" },
	{ href: `${BASE_URL}profile/`, label: "Profile" },
	{ href: `${BASE_URL}osanpo/`, label: "osanpo" },
	{ href: noteConfig.url, label: "note", external: true },
	{ href: `${BASE_URL}works/`, label: "Works" },
];
const normalizePath = (value: string) => (value.endsWith("/") ? value : `${value}/`);
const activePath = normalizePath(currentPath);
---

<header class="site-header">
	<div class="container header-inner">
		<div class="site-brand">
			<p class="site-kicker">ojochi nice log</p>
			<p class="site-title"><a href={BASE_URL}>{title}</a></p>
		</div>
		<nav class="site-nav" aria-label="メインナビゲーション">
			{
				navItems.map((item) => {
					const itemPath = normalizePath(new URL(item.href, "https://example.com").pathname);
					const isHome = itemPath === normalizePath(BASE_URL);
					const isActive = item.external
						? false
						: isHome
							? activePath === itemPath
							: activePath.startsWith(itemPath);

					return (
						<a
							class:list={["site-nav-link", { "is-active": isActive }]}
							href={item.href}
							aria-current={isActive ? "page" : undefined}
							target={item.external ? "_blank" : undefined}
							rel={item.external ? "noreferrer" : undefined}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>
	</div>
</header>
