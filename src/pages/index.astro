---
import PageIntro from "../components/PageIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	NoteConfig,
	NoteThemes,
	OsanpoEntries,
	orientationPoints,
	siteMeta,
	updates,
	Works,
} from "../data/site";

const BASE_URL = import.meta.env.BASE_URL;
const previewWorks = Works.slice(0, 3);
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
	<section class="home-hero">
		<div class="hero-copy">
			<h1>{siteMeta.title}</h1>
			<p class="hero-tagline">{siteMeta.tagline}</p>
			<p class="hero-text">{siteMeta.intro}</p>
		</div>
		<div class="hero-aside">
			<p>
				残したいものを好きなだけ残していきます。
			</p>
			<p class="hero-links">
				<a href={`${BASE_URL}profile/`}>Profile</a>
				<a href={`${BASE_URL}osanpo/`}>Osanpo</a>
				<a href={NoteConfig.url} target="_blank" rel="noreferrer">Note</a>
				<a href={`${BASE_URL}works/`}>Works</a>				
			</p>
		</div>
	</section>

	<section class="section section-lined">
		<PageIntro
			title=""
			lead=""
		/>
		<div class="prose">
			{orientationPoints.map((point) => <p>{point}</p>)}
		</div>
	</section>


	<section class="section section-lined">
		<div class="section-head">
			<div>
				<h4>最近の更新</h4>
			</div>
		</div>
		<ul class="updates-list">
			{
				updates.map((item) => (
					<li class="update-item">
						<p class="entry-meta">{item.date}</p>
						<div class="update-body">
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</div>
					</li>
				))
			}
		</ul>
	</section>


	<section class="section section-lined">
		<div class="section-head">
			<div>
				<h2>お散歩</h2>
			</div>
		</div>
		<div class="text-list">
			{
				OsanpoEntries.slice(0, 3).map((entry) => (
					<article class="text-entry Osanpo-entry">
						<p class="entry-meta">{entry.date} {entry.title}</p>
						<p>{entry.Note}</p>
					</article>
				))
			}
		</div>
		<p class="section-link">
			<a href={`${BASE_URL}osanpo/`}>お散歩の記録へ</a>
		</p>
	</section>


	<section class="section section-lined">
		<div class="section-head">
			<div>
				<h2>Note</h2>
			</div>
		</div>
		<div class="text-list">
			{
				NoteThemes.map((theme) => (
					<article class="text-entry">
						<h3>{theme.title}</h3>
						<p>{theme.description}</p>
					</article>
				))
			}
		</div>
		<p class="section-link">
			<a href={NoteConfig.url} target="_blank" rel="noreferrer">
				{NoteConfig.label}
			</a>
		</p>
	</section>
	
	<section class="section section-lined">
		<div class="section-head">
			<div>
				<h2>ojochi Works</h2>
			</div>
		</div>
		<div class="text-list">
			{
				previewWorks.map((item) => (
					<article class="text-entry">
						<p class="entry-meta">{item.category}</p>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
		<p class="section-link">
			<a href={`${BASE_URL}works/`}>Worksへ</a>
		</p>
	</section>

</BaseLayout>
