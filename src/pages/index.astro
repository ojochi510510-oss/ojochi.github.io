---
import PageIntro from "../components/PageIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	noteConfig,
	noteThemes,
	orientationPoints,
	siteMeta,
	updates,
	works,
} from "../data/site";

const BASE_URL = import.meta.env.BASE_URL;
const previewWorks = works.slice(0, 3);
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
	<section class="home-hero">
		<div class="hero-copy">
			<h1>{siteMeta.title}</h1>
			<p class="hero-tagline">{siteMeta.tagline}</p>
			<p class="hero-text">{siteMeta.intro}</p>
		</div>
		<div class="hero-aside">
			<p>
				プロフィールで人となりを、Works で現在地を、Note で長い文章の置き場所を案内しています。
			</p>
			<p class="hero-links">
				<a href={`${BASE_URL}profile/`}>人物紹介を見る</a>
				<a href={`${BASE_URL}works/`}>Worksを見る</a>
			</p>
		</div>
	</section>

	<section class="section section-lined">
		<PageIntro
			title="この場所について"
			lead="更新情報を追いかける場所ではなく、誰が何に向かっているかを静かに見渡すための入口として整えています。"
		/>
		<div class="prose">
			{orientationPoints.map((point) => <p>{point}</p>)}
		</div>
	</section>

	<section class="section section-lined">
		<div class="section-head">
			<div>
				<h2>いま手を動かしていること</h2>
			</div>
		</div>
		<div class="text-list">
			{
				previewWorks.map((item) => (
					<article class="text-entry">
						<p class="entry-meta">{item.category}</p>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
		<p class="section-link">
			<a href={`${BASE_URL}works/`}>Worksの一覧へ</a>
		</p>
	</section>

	<section class="section section-lined">
		<div class="section-head">
			<div>
				<h2>noteで続けていく話題</h2>
			</div>
		</div>
		<div class="text-list">
			{
				noteThemes.map((theme) => (
					<article class="text-entry">
						<h3>{theme.title}</h3>
						<p>{theme.description}</p>
					</article>
				))
			}
		</div>
		<p class="section-link">
			<a href={noteConfig.url} target="_blank" rel="noreferrer">
				{noteConfig.label}
			</a>
		</p>
	</section>

	<section class="section section-lined">
		<div class="section-head">
			<div>
				<h2>最近の更新</h2>
			</div>
		</div>
		<ul class="updates-list">
			{
				updates.map((item) => (
					<li class="update-item">
						<p class="entry-meta">{item.date}</p>
						<div class="update-body">
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</div>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
