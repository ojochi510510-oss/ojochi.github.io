---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getUnifiedNews } from "../../lib/content";

const allNews = await getUnifiedNews();
const BASE_URL = import.meta.env.BASE_URL;
const resolveLink = (link: string) =>
	link.startsWith("/") ? `${BASE_URL}${link.slice(1)}` : link;
---

<BaseLayout
	title="お知らせ"
	description="サイト更新やブログ公開の通知を時系列でまとめています。"
>
	<section class="section">
		<div class="page-intro">
			<p class="section-kicker">Timeline</p>
			<h1>お知らせ一覧</h1>
			<p>ブログ公開と手動のお知らせを、1つの流れとして見られるようにしています。</p>
		</div>
		<article class="card news-list-card">
			{
				allNews.map((item) => (
					<div class="news-list-item" id={item.slug}>
						<p class="card-date">
							{item.date.toLocaleDateString("ja-JP", {
								year: "numeric",
								month: "2-digit",
								day: "2-digit",
							})}
						</p>
						<p class="card-description">{item.description}</p>
						{
							item.link && (
								<p class="news-link-wrap">
									<a class="news-link" href={resolveLink(item.link)}>
										詳細を見る
									</a>
								</p>
							)
						}
					</div>
				))
			}
		</article>
	</section>
</BaseLayout>
